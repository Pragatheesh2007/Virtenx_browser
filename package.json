{
  "name": "Virtenx-Browser",
  "version": "2.5.0",
  "description": "A modern, secure, memory saving and fast web browser",
  "main": "main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish"
  },
  "test": "echo \"Error: no test specified\" && exit 1",
  "keywords": [],
  "author": "Pragatheeshwaran",
  "license": "ISC",
  "type": "commonjs",
  "repository": "https://github.com/Pragatheesh2007/Viron_browser",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "electron": "^32.0.0"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "update-electron-app": "^3.1.0"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "asar": true,
        "icon": "./assets/icons/icon"
      },
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "Virtenx-Browser",
            "authors": "R.S.Pragatheeshwaran",
            "exe": "Virtenx_Browser.exe",
            "setupExe": "VirtenxBrowserSetup.exe",
            "setupIcon": "./assets/icons/icon.ico",
            "loadingGif": "./assets/splash.png",
            "iconUrl": "https://raw.githubusercontent.com/Pragatheesh2007/Viron_browser/refs/heads/main/assets/icons/icon.ico"
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": ["win32"]
        }
      ]
    }
  }
}